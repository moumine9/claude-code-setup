{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(glab --version)",
      "Read(src/**)",
      "WebFetch(domain:usehooks-ts.com)"
    ],
    "soft_deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(rm -rf:*)",
      "Write(.env*)",
      "Edit(.env*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)"
    ],
    "environment": [
      "This is a frontend development environment using React, TypeScript, and Yarn",
      "GitLab is used for version control — use glab CLI for MR operations",
      "Sensitive files (.env, credentials, keys) must never be read or committed"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/session-context.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/protect-sensitive-files.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/dry-run-guard.sh\""
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": true,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true
  },
  "statusLine": {
    "type": "command",
    "command": "<see README — generated by /claude-hud:setup>"
  }
}
